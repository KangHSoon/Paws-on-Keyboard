# Backend-only secrets. Copy values into IntelliJ Run Configuration environment variables
# or set them in PowerShell before running Spring Boot.

# AI provider.
# If one provider handles text, vision, and image generation, the same key can be used for both.
AI_TEXT_API_KEY=
AI_IMAGE_API_KEY=

# Only needed when image generation is served by a local model or custom gateway.
# Example: http://localhost:7860/api/generate
AI_IMAGE_GENERATE_URL=

# Korea Tourism Organization / data.go.kr service keys.
KTO_TOUR_API_KEY=
KTO_ACCESSIBLE_TOUR_API_KEY=
KTO_DURUNUBI_API_KEY=

# Korea Meteorological Administration / data.go.kr service key.
KMA_SERVICE_KEY=

# Kakao Developers REST API key for backend geocoding/reverse geocoding.
KAKAO_REST_API_KEY=
